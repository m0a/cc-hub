# CC Hub environment variables
# Port / host / password are normally set via CLI flags (-p / -H / -P);
# env vars below are read by the backend at startup.

# Auth password (alternative to -P; used by systemd EnvironmentFile etc.)
CCHUB_PASSWORD=

# JWT signing secret for session tokens.
# Optional — a random 32-byte secret is generated per process if unset
# (set it to keep logins valid across server restarts).
JWT_SECRET=

# Data directory (session metadata, peers.json). Default: ~/.cc-hub
CC_HUB_DATA_DIR=

# Static frontend root served by the backend. Default: ../frontend/dist
STATIC_ROOT=

# GitHub token for `cchub update` (avoids API rate limits; falls back to gh CLI)
GH_TOKEN=
GITHUB_TOKEN=

# Set to 1 or true to enable tmux control mode debug logs (/ws/mux)
DEBUG_MUX=
